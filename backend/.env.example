// .env.example
// LEARNING NOTE:
// .env files store SECRET configuration that should NEVER be committed to Git.
// We use the `dotenv` package to load these into process.env at runtime.
// Copy this file to .env and fill in your real values.

PORT=5000

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=slm_insurance
DB_PORT=3306

# JWT Secret — use a long random string in production
JWT_SECRET=slm_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=your_meta_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# Fast2SMS (India SMS)
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_SENDER_ID=SLMINS

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
